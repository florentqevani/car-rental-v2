# ──────────────────────────────────────────────────────────────────────────────
# Car Rental – environment variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Shared ────────────────────────────────────────────────────────────────────
JWT_SECRET=supersecretjwt_change_me

# ── RaiAccept sandbox credentials ─────────────────────────────────────────────
# Generate in the Merchant portal (Sandbox tab):  https://portal.raiaccept.com
RAIACCEPT_USERNAME=your-sandbox-username
RAIACCEPT_PASSWORD=your-sandbox-password

# Public URL of the frontend app (used for successUrl / failUrl redirects)
# For local dev this is typically http://localhost
RAIACCEPT_APP_URL=http://localhost

# Public URL of web-bff (used for the RaiAccept notification webhook)
# Must be publicly reachable when testing webhooks. Use ngrok for local dev:
#   ngrok http 4000  →  RAIACCEPT_WEBHOOK_URL=https://<id>.ngrok.io
RAIACCEPT_WEBHOOK_URL=http://localhost:4000
